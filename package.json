{
  "name": "pear-youtube-remote",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop remote controller for Pear Desktop YouTube Music API server.",
  "type": "module",
  "main": "src/main/index.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5187 --strictPort",
    "dev:electron": "concurrently -k \"vite --host 127.0.0.1 --port 5187 --strictPort\" \"wait-on tcp:5187 && VITE_DEV_SERVER_URL=http://127.0.0.1:5187 electron .\"",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "youtube-music",
    "pear-desktop",
    "electron",
    "remote-control"
  ],
  "license": "MIT",
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.16",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "dev.bch.pear-youtube-remote",
    "productName": "Pear YouTube Remote",
    "files": [
      "dist/renderer/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "package.json",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo",
      "icon": "assets/icon.png"
    },
    "icon": "assets/icon.png"
  }
}
